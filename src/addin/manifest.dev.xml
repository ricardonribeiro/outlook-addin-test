<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xsi:type="MailApp">

  <!-- Generate a fresh GUID: uuidgen (macOS/Linux) or New-Guid (PowerShell) -->
  <Id>E4D7A916-032D-4AE2-A8AF-F5B8CBFAC177</Id>
  <Version>1.0.1.0</Version>
  <ProviderName>Indicium</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Sync to Test API" />
  <Description DefaultValue="Sends email metadata to the enquiry test harness via an event-driven Azure Function." />

  <!-- Replace icon URLs once you have real assets; run scripts/create-icons.js for placeholders -->
  <IconUrl DefaultValue="https://ambitious-sea-09912e903.7.azurestaticapps.net/assets/icon-80.png" />
  <HighResolutionIconUrl DefaultValue="https://ambitious-sea-09912e903.7.azurestaticapps.net/assets/icon-80.png" />
  <SupportUrl DefaultValue="https://ambitious-sea-09912e903.7.azurestaticapps.net" />

  <AppDomains>
    <AppDomain>ambitious-sea-09912e903.7.azurestaticapps.net</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>

  <!-- Mailbox 1.8: minimum for ExecuteFunction + getAttachmentContentAsync -->
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.8" />
    </Sets>
  </Requirements>

  <!-- FormSettings is required by the schema even for command-only add-ins -->
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://ambitious-sea-09912e903.7.azurestaticapps.net/commands.html" />
        <RequestedHeight>250</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <!-- ReadWriteItem: needed to write notification messages back to the item -->
  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read" />
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <!-- ── VersionOverrides V1_0 ─────────────────────────────────────────────── -->
  <VersionOverrides
    xmlns="http://schemas.microsoft.com/office/mailappversionoverrides"
    xsi:type="VersionOverridesV1_0">

    <Requirements>
      <bt:Sets DefaultMinVersion="1.8">
        <bt:Set Name="Mailbox" />
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <!-- FunctionFile: the page that hosts the function runtime.
               Outlook loads commands.html silently; it loads Office.js + commands.ts. -->
          <FunctionFile resid="Commands.Url" />

          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgReadEnquiryGroup">
                <Label resid="GroupLabel" />

                <!-- ExecuteFunction button — no task pane; runs syncToTestApi() directly -->
                <Control xsi:type="Button" id="syncToTestApiButton">
                  <Label resid="SyncButton.Label" />
                  <Supertip>
                    <Title resid="SyncButton.Label" />
                    <Description resid="SyncButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>syncToTestApi</FunctionName>
                  </Action>
                </Control>

                <Control xsi:type="Button" id="downloadPayloadButton">
                  <Label resid="DownloadButton.Label" />
                  <Supertip>
                    <Title resid="DownloadButton.Label" />
                    <Description resid="DownloadButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>downloadPayload</FunctionName>
                  </Action>
                </Control>

              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://ambitious-sea-09912e903.7.azurestaticapps.net/assets/icon-16.png" />
        <bt:Image id="Icon.32x32" DefaultValue="https://ambitious-sea-09912e903.7.azurestaticapps.net/assets/icon-32.png" />
        <bt:Image id="Icon.80x80" DefaultValue="https://ambitious-sea-09912e903.7.azurestaticapps.net/assets/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://ambitious-sea-09912e903.7.azurestaticapps.net/commands.html" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="Enquiry" />
        <bt:String id="SyncButton.Label" DefaultValue="Sync to Test API" />
        <bt:String id="DownloadButton.Label" DefaultValue="Download Payload" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="SyncButton.Tooltip" DefaultValue="Send this email&apos;s metadata to the enquiry test harness." />
        <bt:String id="DownloadButton.Tooltip" DefaultValue="Download this email&apos;s payload and attachments as a ZIP file." />
      </bt:LongStrings>
    </Resources>

    <!-- ── VersionOverrides V1_1 (nested) ──────────────────────────────────────
         V1_1 adds Runtimes support. Outlook clients that support V1_1 use this
         block; older clients fall back to V1_0 above. -->
    <VersionOverrides
      xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1"
      xsi:type="VersionOverridesV1_1">

      <Requirements>
        <bt:Sets DefaultMinVersion="1.8">
          <bt:Set Name="Mailbox" />
        </bt:Sets>
      </Requirements>

      <Hosts>
        <Host xsi:type="MailHost">

          <!-- Runtime declaration: Outlook loads commands.html once and keeps it
               alive for the duration of the add-in session (lifetime="short" =
               loaded on demand, unloaded after the function completes). -->
          <Runtimes>
            <Runtime resid="Commands.Url" lifetime="short" />
          </Runtimes>

          <DesktopFormFactor>
            <FunctionFile resid="Commands.Url" />
            <ExtensionPoint xsi:type="MessageReadCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="msgReadEnquiryGroup">
                  <Label resid="GroupLabel" />
                  <Control xsi:type="Button" id="syncToTestApiButton">
                    <Label resid="SyncButton.Label" />
                    <Supertip>
                      <Title resid="SyncButton.Label" />
                      <Description resid="SyncButton.Tooltip" />
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon.16x16" />
                      <bt:Image size="32" resid="Icon.32x32" />
                      <bt:Image size="80" resid="Icon.80x80" />
                    </Icon>
                    <Action xsi:type="ExecuteFunction">
                      <FunctionName>syncToTestApi</FunctionName>
                    </Action>
                  </Control>

                  <Control xsi:type="Button" id="downloadPayloadButton">
                    <Label resid="DownloadButton.Label" />
                    <Supertip>
                      <Title resid="DownloadButton.Label" />
                      <Description resid="DownloadButton.Tooltip" />
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon.16x16" />
                      <bt:Image size="32" resid="Icon.32x32" />
                      <bt:Image size="80" resid="Icon.80x80" />
                    </Icon>
                    <Action xsi:type="ExecuteFunction">
                      <FunctionName>downloadPayload</FunctionName>
                    </Action>
                  </Control>

                </Group>
              </OfficeTab>
            </ExtensionPoint>
          </DesktopFormFactor>
        </Host>
      </Hosts>

      <Resources>
        <bt:Images>
          <bt:Image id="Icon.16x16" DefaultValue="https://ambitious-sea-09912e903.7.azurestaticapps.net/assets/icon-16.png" />
          <bt:Image id="Icon.32x32" DefaultValue="https://ambitious-sea-09912e903.7.azurestaticapps.net/assets/icon-32.png" />
          <bt:Image id="Icon.80x80" DefaultValue="https://ambitious-sea-09912e903.7.azurestaticapps.net/assets/icon-80.png" />
        </bt:Images>
        <bt:Urls>
          <bt:Url id="Commands.Url" DefaultValue="https://ambitious-sea-09912e903.7.azurestaticapps.net/commands.html" />
        </bt:Urls>
        <bt:ShortStrings>
          <bt:String id="GroupLabel" DefaultValue="Enquiry" />
          <bt:String id="SyncButton.Label" DefaultValue="Sync to Test API" />
          <bt:String id="DownloadButton.Label" DefaultValue="Download Payload" />
        </bt:ShortStrings>
        <bt:LongStrings>
          <bt:String id="SyncButton.Tooltip" DefaultValue="Send this email&apos;s metadata to the enquiry test harness." />
          <bt:String id="DownloadButton.Tooltip" DefaultValue="Download this email&apos;s payload and attachments as a ZIP file." />
        </bt:LongStrings>
      </Resources>

      <!-- SSO: <Resource> must match the App ID URI configured in SETUP.md Step 1a.
           Local dev: api://ambitious-sea-09912e903.7.azurestaticapps.net/<client-id> -->
      <WebApplicationInfo>
        <Id>4d9c4570-30c2-490d-9968-8fa2b6fea2df</Id>
        <Resource>api://ambitious-sea-09912e903.7.azurestaticapps.net/4d9c4570-30c2-490d-9968-8fa2b6fea2df</Resource>
        <Scopes>
          <Scope>openid</Scope>
          <Scope>profile</Scope>
          <Scope>offline_access</Scope>
          <Scope>api://ambitious-sea-09912e903.7.azurestaticapps.net/4d9c4570-30c2-490d-9968-8fa2b6fea2df/access_as_user</Scope>
        </Scopes>
      </WebApplicationInfo>

    </VersionOverrides>
    <!-- end V1_1 -->

  </VersionOverrides>
  <!-- end V1_0 -->

</OfficeApp>
