{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "lib": ["ES2020", "DOM"],
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vite/client", "office-js"]
  },
  "include": ["**/*.ts"],
  "exclude": ["dist", "node_modules", "public", "vite.config.ts"]
}
