{
  "IsEncrypted": false,
  "Values": {
    "AzureWebJobsStorage": "DefaultEndpointsProtocol=https;AccountName=<storage-account-name>;AccountKey=<access-key>;EndpointSuffix=core.windows.net",
    "FUNCTIONS_WORKER_RUNTIME": "python",

    "TENANT_ID": "<your-directory-tenant-id>",
    "API_AUDIENCE": "api://localhost:3000/<your-client-id>",
    "ALLOWED_CORS_ORIGIN": "https://localhost:3000",

    "STORAGE_ACCOUNT_NAME": "<storage-account-name>",
    "STORAGE_ACCOUNT_KEY": "<storage-account-key>",
    "BLOB_CONTAINER_NAME": "submissions",

    "SERVICEBUS_CONNECTION_STRING": "<namespace-primary-connection-string>",
    "SERVICEBUS_FQDN": "<your-namespace>.servicebus.windows.net",
    "SERVICEBUS_QUEUE_NAME": "submission-queue",

    "ServiceBusConnection": "<namespace-primary-connection-string>"
  }
}
