# Dev environment — add-in served from Azure Static Web Apps, functions on Azure.
#
# Usage:
#   cp infra/envs/dev.tfvars.example infra/envs/dev.tfvars
#   terraform apply -var-file=envs/dev.tfvars
#
# The SWA hostname (needed for api_audience and add_in_origin) is only known
# AFTER the first Terraform apply. Follow this two-step workflow:
#
#   Step 1 — first apply (use local.tfvars, or set api_audience to the localhost placeholder):
#     terraform apply -var-file=envs/local.tfvars
#
#   Step 2 — get the SWA hostname:
#     terraform output addin_url
#     # e.g. https://proud-pond-0123456789.azurestaticapps.net
#
#   Step 3 — fill in the two SWA placeholders below, then apply again:
#     terraform apply -var-file=envs/dev.tfvars
#
# Pair with src/addin/.env.dev for the add-in build (npm run build uses --mode dev).

# ── Azure subscription ─────────────────────────────────────────────────────────
subscription_id = "REPLACE_WITH_YOUR_SUBSCRIPTION_ID"

# ── Identity ───────────────────────────────────────────────────────────────────
tenant_id = "REPLACE_WITH_YOUR_TENANT_ID"
client_id = "REPLACE_WITH_YOUR_CLIENT_ID"

# App ID URI for dev — must match the SWA hostname.
# Add this as a SECOND App ID URI on the App Registration (keep the localhost one too).
# Format: api://<swa-hostname>/<client-id>
# Get swa-hostname from: terraform output addin_url  (strip the leading https://)
api_audience = "api://REPLACE_WITH_SWA_HOSTNAME/REPLACE_WITH_YOUR_CLIENT_ID"

# ── Deployment ─────────────────────────────────────────────────────────────────
location     = "uksouth"
name_prefix  = "oaddintest"   # must match what was used in the first apply
swa_location = "westeurope"

# Origin the add-in is served from — SWA hostname for dev.
add_in_origin = "https://REPLACE_WITH_SWA_HOSTNAME"

# ── Tagging (Indicium/Mesh AI policy) ─────────────────────────────────────────
owner_email = "firstname.lastname@mesh-ai.com"
end_date    = "170826"
project     = "outlook-addin-test-harness"
description = "Outlook add-in test harness — dev."
